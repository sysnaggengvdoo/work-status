<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="作業指示書">
  <link rel="manifest" href="manifest.json">
  <title>過去検索</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
  <style>
    /* ★ 技術計算のiframe用のスタイルを追加 */
    #calc-iframe {
        display: none;
        width: 100%;
        height: calc(100vh - 60px); /* ナビゲーションバーの高さを引く */
        border: none;
    }
  </style>
</head>
<body class="bg-gray-100 font-sans pb-12" style="overscroll-behavior-y: none;">
  <div id="app" class="w-full mx-auto bg-white min-h-screen shadow-lg">
    
    <header id="past-header" class="bg-blue-700 text-white p-4 sticky top-0 z-40 shadow-md">
      <div class="flex justify-center items-center mb-3">
        <h1 class="text-xl font-bold tracking-wider">過去検索</h1>
      </div>
      
      <div class="relative">
        <input 
          type="text" 
          v-model="searchQuery" 
          placeholder="整理No、顧客名、担当、日付で検索..." 
          class="w-full p-2 rounded text-black focus:outline-none focus:ring-2 focus:ring-blue-400 text-sm"
        >
      </div>
      
      <div class="mt-2 flex gap-2">
        <button @click="showYesterday" class="flex-1 bg-green-500 hover:bg-green-600 text-white py-1.5 rounded text-sm font-bold shadow transition">
          前日表示
        </button>
        <button @click="clearSearch" class="bg-gray-300 hover:bg-gray-400 text-gray-800 px-3 py-1.5 rounded text-sm font-bold shadow transition">
          クリア
        </button>
        <button @click="refreshData" class="bg-amber-500 hover:bg-amber-600 text-white px-3 py-1.5 rounded text-sm font-bold shadow transition">
          🔄 更新
        </button>
      </div>
    </header>

    <main id="past-log-main" class="p-4">
      <div v-if="isLoading" class="text-center py-10">
        <div class="animate-spin h-10 w-10 border-4 border-blue-500 border-t-transparent rounded-full mx-auto mb-4"></div>
        <p class="text-gray-600 font-bold">データを読み込み中...</p>
      </div>
      <div v-else-if="error" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
        {{ error }}
      </div>
      <div v-else>
        <p class="text-sm text-gray-500 mb-3 text-right">
          該当: <span class="font-bold text-gray-800">{{ filteredGroupedLogs.length }}</span> 案件 
        </p>
        
        <div class="space-y-6">
          <div v-for="group in filteredGroupedLogs" :key="group.no" class="bg-white border-2 border-gray-200 rounded-xl shadow-md overflow-hidden">
        <div class="bg-gray-800 text-white p-3 flex flex-col gap-1">
              <div class="flex justify-between items-start">
                <span class="font-black text-xl text-blue-300">{{ group.no }}</span>
                <div class="flex flex-col items-end gap-1">
                  <span class="bg-gray-600 px-2 py-1 rounded text-xs">履歴 {{ group.records.length }}件</span>
                  <span v-if="group.output" class="text-xs font-bold text-white">出力: {{ group.output }}</span>
                </div>
              </div>
              <div class="text-sm font-bold border-t border-gray-600 pt-1 mt-1">
                顧客名: {{ group.customer }}
              </div>
            </div>
            <div class="p-4 space-y-5 bg-gray-50">
            <div v-for="(log, idx) in group.records" :key="idx" class="relative pl-4 border-l-4 border-blue-400">
                <div class="flex justify-between items-center mb-1">
                  <div class="flex items-center gap-2">
                    <span class="text-gray-600 text-xs font-bold bg-gray-200 px-2 py-0.5 rounded">
                      {{ formatDate(log['TS'] || log['タイムスタンプ'] || log['日付']) }}
                    </span>
                    <span v-if="log['完了確認']" 
                          class="text-[10px] font-bold px-1.5 py-0.5 rounded border"
                          :class="{
                            'bg-gray-500 text-white border-gray-500': log['完了確認'] === '完了',
                            'bg-yellow-200 text-yellow-800 border-yellow-400': log['完了確認'] === '完了予定',
                            'bg-red-100 text-red-600 border-red-300': log['完了確認'] === '繰越',
                            'bg-white text-gray-500 border-gray-300': !['完了', '完了予定', '繰越'].includes(log['完了確認'])
                          }">
                      {{ log['完了確認'] }}
                    </span>
                  </div>
                  <span class="text-sm font-bold text-blue-800">担当: {{ log['担当'] }}</span>
                </div>
                <p class="text-sm mb-2 text-gray-800">
                  <span class="font-bold text-gray-500 text-xs">作業内容:</span><br>
                  {{ log['作業内容'] }}
                </p>
                <div class="bg-yellow-100 p-3 rounded border border-yellow-300 shadow-sm mt-2">
                  <p class="font-bold text-yellow-800 mb-1 text-xs">備考・引き継ぎ:</p>
                  <p class="text-gray-800 whitespace-pre-wrap text-sm">{{ log['備考（引継ぎ・進捗状況等）'] || log['備考'] || 'なし' }}</p>
                </div>
              </div>
            </div>
          </div>
          <div v-if="filteredGroupedLogs.length === 0" class="text-center py-10 text-gray-500 font-bold">
            履歴が見つかりません。
          </div>
        </div>
      </div>
    </main>

    <iframe id="calc-iframe" src="https://sysnaggengvdoo.github.io/eng-calc/"></iframe>
    
    <nav class="fixed bottom-0 left-0 right-0 w-full mx-auto bg-white border-t-2 border-gray-300 flex justify-around z-50 shadow-[0_-5px_10px_rgba(0,0,0,0.05)]">
      <div onclick="window.location.replace('index.html');" class="cursor-pointer flex items-center justify-center w-1/3 py-2 text-gray-500 border-r border-gray-200 font-bold text-lg hover:bg-gray-50 transition">
        今日の作業
      </div>
      <div id="nav-past" onclick="switchPastTab('past')" class="cursor-pointer flex items-center justify-center w-1/3 py-2 text-blue-700 bg-blue-50 font-bold text-lg border-t-4 border-blue-700 transition">
        過去検索
      </div>
      <div id="nav-calc" onclick="switchPastTab('calc')" class="cursor-pointer flex items-center justify-center w-1/3 py-2 text-gray-500 border-l border-gray-200 font-bold text-lg hover:bg-gray-50 transition">
        計算
      </div>
    </nav>
  </div>

  <script>
    function switchPastTab(tabName) {
        const pastMain = document.getElementById('past-log-main');
        const calcFrame = document.getElementById('calc-iframe');
        const header = document.getElementById('past-header');
        
        const navPast = document.getElementById('nav-past');
        const navCalc = document.getElementById('nav-calc');

        if (tabName === 'calc') {
            pastMain.style.display = 'none';
            calcFrame.style.display = 'block';
            header.style.display = 'none'; 

            navPast.className = "cursor-pointer flex items-center justify-center w-1/3 py-2 text-gray-500 border-r border-gray-200 font-bold text-lg hover:bg-gray-50 transition";
            navCalc.className = "cursor-pointer flex items-center justify-center w-1/3 py-2 text-blue-700 bg-blue-50 font-bold text-lg border-l border-t-4 border-blue-700 transition";
        } else {
            pastMain.style.display = 'block';
            calcFrame.style.display = 'none';
            header.style.display = 'block';

            navPast.className = "cursor-pointer flex items-center justify-center w-1/3 py-2 text-blue-700 bg-blue-50 font-bold text-lg border-t-4 border-blue-700 transition";
            navCalc.className = "cursor-pointer flex items-center justify-center w-1/3 py-2 text-gray-500 border-l border-gray-200 font-bold text-lg hover:bg-gray-50 transition";
        }
    }

    const { createApp, ref, computed, onMounted } = Vue;

    createApp({
      setup() {
        const API_URL = "https://script.google.com/macros/s/AKfycbxVOgnDwBg-VwK6kZSZ8GbYnTykbALW-KPiBLoTO4z0t9O16QWBlFVXlLWL-xCF0dLj/exec";
        
        // ★ キャッシュ用キー
        const CACHE_KEY = "sec_past_logs_cache_v36";

        const allLogs = ref([]);
        const searchQuery = ref("");
        const isLoading = ref(true);
        const error = ref(null);

        const formatDate = (val) => {
          if (!val) return '日付不明';
          return String(val).split(' ')[0];
        };

        // ★改修1：爆速キャッシュ＆裏更新ロジック
        const fetchAllData = async (forceRefresh = false) => {
          if (forceRefresh) {
            localStorage.removeItem(CACHE_KEY);
            allLogs.value = [];
            isLoading.value = true;
          } else {
            const cachedStr = localStorage.getItem(CACHE_KEY);
            if (cachedStr) {
              try {
                allLogs.value = JSON.parse(cachedStr);
                isLoading.value = false; // 一瞬で画面表示
              } catch (e) {
                console.warn("キャッシュパース失敗", e);
                isLoading.value = true;
              }
            } else {
              isLoading.value = true;
            }
          }

          try {
            const response = await fetch(`${API_URL}?_=${new Date().getTime()}`);
            const json = await response.json();
            
            if(json.status === "success") {
              const freshData = json.data.reverse();
              allLogs.value = freshData;
              localStorage.setItem(CACHE_KEY, JSON.stringify(freshData));
            } else {
              if (allLogs.value.length === 0) error.value = "エラー: " + json.message;
            }
          } catch (e) {
            if (allLogs.value.length === 0) error.value = "通信エラーが発生しました。";
            console.error("API通信エラー", e);
          } finally {
            isLoading.value = false;
          }
        };

        const refreshData = () => {
          fetchAllData(true);
        };

        const groupedLogs = computed(() => {
          const groups = {};
          allLogs.value.forEach(log => {
            const no = String(log['整理№'] || log['整理No'] || log['整理No.'] || 'Noなし');
            if (!groups[no]) {
              groups[no] = { no: no, customer: String(log['顧客名'] || '未入力'), output: String(log['出'] || log['出力'] || ''), records: [] };
            }
            if (!groups[no].output && (log['出'] || log['出力'])) {
              groups[no].output = String(log['出'] || log['出力']);
            }
            groups[no].records.push(log);
          });
          return Object.values(groups);
        });

        // ★改修2：全角/半角スペース対応＆AND（複数条件）検索ロジック
        const filteredGroupedLogs = computed(() => {
          if (!searchQuery.value) return groupedLogs.value;
          
          // 検索窓の文字を小文字化し、全角スペースを半角に変換し、配列化する
          const searchWords = searchQuery.value.toLowerCase().replace(/　/g, ' ').split(' ').filter(w => w !== '');

          return groupedLogs.value.filter(group => {
            // その案件が持つすべての情報（タイトル、すべての履歴）を1つの巨大な文字列にする
            let groupText = `${group.no} ${group.customer} ${group.output} `;
            group.records.forEach(log => {
              groupText += `${log['TS'] || log['タイムスタンプ'] || log['日付'] || ''} ${log['作業内容'] || ''} ${log['担当'] || ''} ${log['備考（引継ぎ・進捗状況等）'] || log['備考'] || ''} ${log['完了確認'] || ''} `;
            });
            groupText = groupText.toLowerCase();

            // 入力されたすべてのキーワード（searchWords）が、groupTextの中に含まれているか（AND検索）
            return searchWords.every(word => groupText.includes(word));
          });
        });

        const totalRecordsCount = computed(() => filteredGroupedLogs.value.reduce((sum, group) => sum + group.records.length, 0));

        const showYesterday = () => {
          const d = new Date();
          d.setDate(d.getDate() - 1);
          searchQuery.value = `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;
        };

        const clearSearch = () => searchQuery.value = "";
        
        onMounted(() => fetchAllData());
        
        return { 
          searchQuery, 
          filteredGroupedLogs, 
          totalRecordsCount, 
          isLoading, 
          error, 
          showYesterday, 
          clearSearch,
          refreshData,
          formatDate 
        };
      }
    }).mount('#app');
  </script>
</body>
</html>
